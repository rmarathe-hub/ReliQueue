# Application
APP_NAME=ReliQueue
APP_ENV=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
# Local API + Docker Postgres: use localhost
# Docker Compose API service: use host `db` (set automatically in docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://reliqueue:reliqueue@localhost:5432/reliqueue
TEST_DATABASE_URL=postgresql+asyncpg://reliqueue:reliqueue@localhost:5432/reliqueue_test
WORKER_LEASE_SECONDS=60
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_MAX_DELAY_SECONDS=300.0
RETRY_JITTER_ENABLED=true
